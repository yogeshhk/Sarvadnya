# Environment Variables Reference
# Set these in your shell or system environment — do NOT use a .env file.
#
# Windows (PowerShell):
#   $env:GROQ_API_KEY = "your_key_here"
#
# Linux / macOS:
#   export GROQ_API_KEY="your_key_here"
#
# Required
GROQ_API_KEY=your_groq_api_key_here

# Optional fallback providers
OPENAI_API_KEY=your_openai_api_key_here_optional
ANTHROPIC_API_KEY=your_anthropic_api_key_here_optional

# Optional overrides (defaults come from config.yaml)
LOG_LEVEL=INFO
LLM_MODEL=llama3-70b-8192
